#include <stdio.h>

int main()
{
    int choice;

    do
    {
        printf("\n1. Hello\n2. Bye\n3. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        if(choice == 1)
            printf("Hello!");
        else if(choice == 2)
            printf("Bye!");

    } 
    while(choice != 3);

    return 0;
}
